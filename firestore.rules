rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation for Detection
    function isValidDetection(data) {
      return data.keys().hasAll(['timestamp', 'location', 'plasticType', 'confidence']) &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.plasticType in ['macro', 'micro'] &&
             data.confidence is number &&
             data.confidence >= 0 && data.confidence <= 1;
    }

    match /detections/{detectionId} {
      allow read: if true; // Publicly viewable detections for transparency
      allow create: if true; // In a real app, this would be backend-only or restricted to authorized analysts
      allow update, delete: if false; // Scientific data is immutable
    }

    match /trajectories/{trajectoryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /environmental_logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /system/{docId} {
      allow read: if true;
    }
  }
}
